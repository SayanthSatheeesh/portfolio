# ──────────────────────────────────────────────
# .gitignore — Sayanth Satheesh Portfolio
# Maintained by: senior dev conventions
# ──────────────────────────────────────────────

# ── Node / npm ────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
package-lock.json   # keep only if you don't use it for CI lockfile checks

# ── Testing Artefacts ─────────────────────────
playwright-report/
test-results/
.playwright/
coverage/
*.lcov

# ── Environment & Secrets ─────────────────────
.env
.env.*
!.env.example       # allow the template to be committed
*.pem
*.key

# ── OS-generated files ────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editor / IDE ──────────────────────────────
.vscode/
!.vscode/extensions.json   # allow recommended extensions list
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.swp
*.swo
*~

# ── Build Outputs ─────────────────────────────
dist/
build/
out/
.cache/
.parcel-cache/

# ── Logs ──────────────────────────────────────
logs/
*.log

# ── Backup / Scratch Folders ──────────────────
backup/
tmp/
temp/
scratch/

# ── TypeScript ────────────────────────────────
*.tsbuildinfo

# ── Misc ──────────────────────────────────────
.gemini/
